{
  "name": "@youvico/cli",
  "version": "1.1.1",
  "description": "Official command-line interface for YouViCo",
  "author": "YouViCo",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "youvico": "dist/cli.js"
  },
  "files": [
    "dist/**/*"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "lint": "eslint \"{src,tests}/**/*.ts\" --fix",
    "pack:dry-run": "pnpm pack --dry-run",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "youvico",
    "cli",
    "command-line",
    "web-api",
    "api",
    "sdk",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/youvicohq/cli.git"
  },
  "bugs": {
    "url": "https://github.com/youvicohq/cli/issues"
  },
  "homepage": "https://github.com/youvicohq/cli#readme",
  "dependencies": {
    "@inquirer/prompts": "^7.2.1",
    "@youvico/api": "^1.0.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=8.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
